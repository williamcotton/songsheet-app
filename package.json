{
  "name": "songsheet-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.tsx",
    "start": "NODE_ENV=production tsx server.ts",
    "preview": "NODE_ENV=production tsx server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "clean:screenshots": "rm -rf screenshots",
    "test:e2e:readme-screenshots": "playwright test e2e/readme-screenshots.spec.ts",
    "refresh:readme-screenshots": "npm run clean:screenshots && npm run test:e2e:readme-screenshots"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "graphql": "^16.13.0",
    "path-to-regexp": "^8.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "songsheet": "^7.5.0",
    "tone": "^14.9.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^27.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
